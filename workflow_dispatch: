name: Sync from source repo

on:
  schedule:
    # Sincroniza a cada 6 horas
    - cron: '0 */6 * * *'
  workflow_dispatch:

jobs:
  sync:
    runs-on: ubuntu-latest
    
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          token: ${{ secrets.SYNC_TOKEN }}

      - name: Configure Git
        run: |
          git config --global user.name "GitHub Actions Bot"
          git config --global user.email "actions@github.com"

      - name: Sync from upstream
        run: |
          git remote add upstream https://github.com/wodnutritiongyn-cyber/sam-esthetic-lash-shop.git || git remote set-url upstream https://github.com/wodnutritiongyn-cyber/sam-esthetic-lash-shop.git
          git fetch upstream main
          git merge upstream/main --allow-unrelated-histories -m "Sync: $(date '+%Y-%m-%d %H:%M:%S')"
          git push origin main

      - name: Push changes
        if: success()
        run: |
          echo "✅ Sincronização concluída com sucesso!"
