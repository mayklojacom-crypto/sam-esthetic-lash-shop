name: Sync from source repo

on:
  schedule:
    - cron: '0 */6 * * *'
  workflow_dispatch:

jobs:
  sync:
    runs-on: ubuntu-latest
    
    steps:
      - uses: actions/checkout@v3
        with:
          fetch-depth: 0
          token: ${{ secrets.GITHUB_TOKEN }}

      - name: Sync repository
        run: |
          git config user.name "GitHub Actions"
          git config user.email "github-actions@github.com"
          
          git remote add upstream https://github.com/wodnutritiongyn-cyber/sam-esthetic-lash-shop.git || true
          git fetch upstream
          
          # Identifica a branch principal
          MAIN_BRANCH=$(git rev-parse --abbrev-ref HEAD)
          
          git merge upstream/$MAIN_BRANCH --allow-unrelated-histories -m "Sync: $(date)"
          git push origin $MAIN_BRANCH
